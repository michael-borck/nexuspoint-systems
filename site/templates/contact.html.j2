{% extends "base.html.j2" %}

{% block title %}Contact — NexusPoint Systems{% endblock %}

{% block content %}
<section class="section-pad">
    <div class="wrap">
        <p class="eyebrow">Contact</p>
        <h1 style="max-width: 16ch; margin-bottom: var(--np-px-5);">Get in touch.</h1>
        <p class="lead" style="max-width: 60ch; font-size: 1.35rem;">Perth-based. The NOC is 24/7 — everything else operates standard business hours.</p>
    </div>
</section>

<section class="section-pad" style="background: var(--np-bg-2); border-top: 1px solid var(--np-line); border-bottom: 1px solid var(--np-line);">
    <div class="wrap">
        <div class="cap-grid">
            <article class="cap">
                <div class="cap-num">CTC_01 / HQ</div>
                <h3>Perth office</h3>
                <p style="margin-bottom: var(--np-px-2);">Level 6, 28 The Esplanade<br>Perth WA 6000</p>
                <p class="mono">+61 8 6000 0000</p>
            </article>
            <article class="cap">
                <div class="cap-num">CTC_02 / NOC</div>
                <h3>24/7 operations</h3>
                <p style="margin-bottom: var(--np-px-2);">P1/P2 incidents<br>Direct to on-call</p>
                <p class="mono">noc@nexuspointsystems.com.au</p>
            </article>
            <article class="cap">
                <div class="cap-num">CTC_03 / SALES</div>
                <h3>New engagements</h3>
                <p style="margin-bottom: var(--np-px-2);">Discovery call scoping<br>Mon–Fri 09:00–17:00 AWST</p>
                <p class="mono">hello@nexuspointsystems.com.au</p>
            </article>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="wrap-narrow">
        <p class="eyebrow">Careers enquiries</p>
        <h2 style="margin-bottom: var(--np-px-4);">Talking to us about a role?</h2>
        <p style="color: var(--np-text-muted); font-size: 1.1rem; line-height: 1.7;">All current openings are listed on the careers page. If you don't see your role but think you'd add value here, send a short note to <span class="mono" style="color: var(--np-blue);">careers@nexuspointsystems.com.au</span> — Jordan reads everything.</p>
    </div>
</section>
{% endblock %}
