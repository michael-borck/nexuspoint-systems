{% extends "base.html.j2" %}

{% block title %}About — NexusPoint Systems{% endblock %}

{% block content %}
<section class="section-pad">
    <div class="wrap">
        <p class="eyebrow">About NexusPoint</p>
        <h1 style="max-width: 18ch; margin-bottom: var(--np-px-5);">A 35-person team running mid-market WA infrastructure.</h1>
        <p class="lead" style="max-width: 60ch; font-size: 1.35rem;">Founded in {{ profile.founded or 2016 }} on a simple idea — bring enterprise-grade IT operations to organisations that aren't enterprises.</p>
    </div>
</section>

<section class="section-pad" style="background: var(--np-bg-2); border-top: 1px solid var(--np-line); border-bottom: 1px solid var(--np-line);">
    <div class="wrap">
        <div class="section-header">
            <div>
                <p class="eyebrow">Profile</p>
                <h2>What we are.</h2>
            </div>
            <div class="lead">
                {{ (profile.description or "")|trim }}
            </div>
        </div>

        {% if profile.key_facts %}
        <div class="cap-grid">
            {% for fact in profile.key_facts[:6] %}
            <article class="cap">
                <div class="cap-num">{{ "%02d"|format(loop.index) }} / FACT</div>
                <p style="color: var(--np-text); font-size: 1.05rem; line-height: 1.5; font-family: var(--np-font-display); font-weight: 500;">{{ fact }}</p>
            </article>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>

<section class="section-pad">
    <div class="wrap">
        <div class="section-header">
            <div>
                <p class="eyebrow">Leadership</p>
                <h2>Who runs the place.</h2>
            </div>
            <p class="lead">A small leadership group by design. Decisions move fast and the people approving the work also do the work.</p>
        </div>

        <div class="cap-grid">
            {% for emp in employees if emp.tier == 'executive' %}
            <article class="cap">
                <div class="cap-num">{{ "%02d"|format(loop.index) }} / EXEC</div>
                <h3 style="font-size: 1.2rem;">{{ emp.name }}</h3>
                <p style="color: var(--np-blue); font-family: var(--np-font-mono); font-size: 0.75rem; letter-spacing: 0.04em; margin-bottom: var(--np-px-3);">{{ emp.role }}</p>
                <p>{{ (emp.background or "")[:240] }}{% if (emp.background or "")|length > 240 %}…{% endif %}</p>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="cta-banner">
    <div class="wrap">
        <div class="cta-banner-inner">
            <div>
                <h2>Want to know what we actually deliver?</h2>
                <p>Our services page covers managed IT, cloud, and security in plain language — no vendor-speak.</p>
            </div>
            <a href="/services.html" class="btn btn-cyan btn-arrow cta-banner-btn">Services</a>
        </div>
    </div>
</section>
{% endblock %}
