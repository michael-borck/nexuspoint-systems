{% extends "base.html.j2" %}

{% block title %}Careers — NexusPoint Systems{% endblock %}

{% block content %}
<section class="section-pad">
    <div class="wrap">
        <p class="eyebrow">Careers / FY26 intake</p>
        <h1 style="max-width: 18ch; margin-bottom: var(--np-px-5);">Small team, real systems, fast feedback.</h1>
        <p class="lead" style="max-width: 60ch; font-size: 1.35rem;">We're 35 people running production systems for 120+ clients. There's no bench, no graduate cohort to babysit you, and no work that doesn't matter. If that sounds good, keep reading.</p>
    </div>
</section>

<section class="section-pad-sm" style="background: var(--np-bg-2); border-top: 1px solid var(--np-line); border-bottom: 1px solid var(--np-line);">
    <div class="wrap">
        <div class="section-header">
            <div>
                <p class="eyebrow">Open roles</p>
                <h2>{{ jobs|length }} positions open.</h2>
            </div>
            <p class="lead">Most roles are Perth-based. Hybrid is supported once you're up to speed. The on-call rotation is real but fairly compensated.</p>
        </div>

        <div class="cap-grid">
            {% for job in jobs %}
            <article class="cap" style="display: flex; flex-direction: column;">
                <div class="cap-num">ROLE_{{ "%02d"|format(loop.index) }} / {{ (job.employment_type or "FULL")|upper|replace(" ", "_") }}</div>
                <h3 style="font-size: 1.2rem; max-width: 18ch;">{{ job.title }}</h3>
                <p style="color: var(--np-blue); font-family: var(--np-font-mono); font-size: 0.7rem; margin-bottom: var(--np-px-3);">{{ job.department or "" }}</p>
                <p style="flex: 1;">{{ (job.brief or job.summary or "")[:180] }}{% if (job.brief or job.summary or "")|length > 180 %}…{% endif %}</p>
                <a href="/careers/{{ job.slug }}.html" class="btn btn-primary btn-arrow" style="align-self: flex-start; margin-top: var(--np-px-4);">Read role</a>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="wrap">
        <div class="section-header">
            <div>
                <p class="eyebrow">Hiring process</p>
                <h2>Three steps. No theatre.</h2>
            </div>
            <p class="lead">We don't run assessment centres. We don't ask brain teasers. We have a conversation about the work, and then we make a decision quickly.</p>
        </div>

        <div class="cap-grid">
            <article class="cap">
                <div class="cap-num">STEP_01</div>
                <h3>Apply</h3>
                <p>Submit your CV through the role page. A real human at NexusPoint reads every application — no automated screening.</p>
            </article>
            <article class="cap">
                <div class="cap-num">STEP_02</div>
                <h3>Conversation</h3>
                <p>One call with the hiring manager, about 30 minutes. Real questions about the work and how you think.</p>
            </article>
            <article class="cap">
                <div class="cap-num">STEP_03</div>
                <h3>Decision</h3>
                <p>We come back to you within a week. Salary, conditions, and start date are on the table at offer stage — no negotiation games.</p>
            </article>
        </div>
    </div>
</section>

<!-- AnythingLLM hiring desk chatbot -->
<script
  data-embed-id="c6342dc9-36c2-45c8-9053-311af789bc02"
  data-base-api-url="https://chat.eduserver.au/api/embed"
  src="https://chat.eduserver.au/embed/anythingllm-chat-widget.min.js">
</script>
{% endblock %}
