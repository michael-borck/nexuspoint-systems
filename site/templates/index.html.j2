{% extends "base.html.j2" %}

{% block title %}NexusPoint Systems — Connecting Business to What's Next{% endblock %}

{% block content %}
<section class="hero">
    <div class="hero-inner">
        <div class="hero-content">
            <p class="eyebrow">Managed IT / Cloud / Cybersecurity</p>
            <h1>
                Quietly running<br>
                <span class="accent">what your business depends on.</span>
            </h1>
            <p class="hero-tagline">{{ company.tagline or "Connecting business to what's next." }} 120+ Western Australian organisations trust us with their infrastructure, their security, and the 3am alerts they'd rather not hear about.</p>
            <div class="hero-cta">
                <a href="/services.html" class="btn btn-primary btn-arrow">Our services</a>
                <a href="/careers.html" class="btn btn-ghost btn-arrow">Join the team</a>
            </div>
        </div>

        <aside class="monitor-card" aria-label="Live operations panel">
            <div class="monitor-header">
                <span>NexusPoint NOC // live</span>
                <div class="monitor-dots">
                    <span class="live"></span>
                    <span class="live"></span>
                    <span></span>
                </div>
            </div>
            <div class="monitor-row">
                <span>active_clients</span>
                <strong class="info">120</strong>
            </div>
            <div class="monitor-row">
                <span>monitored_endpoints</span>
                <strong>4,832</strong>
            </div>
            <div class="monitor-row">
                <span>uptime_30d</span>
                <strong class="ok">99.74%</strong>
            </div>
            <div class="monitor-row">
                <span>open_incidents</span>
                <strong class="info">3</strong>
            </div>
            <div class="monitor-row">
                <span>p1_incidents_30d</span>
                <strong>0</strong>
            </div>
            <div class="monitor-row">
                <span>response_avg</span>
                <strong class="ok">11m 24s</strong>
            </div>
            <div class="monitor-row">
                <span>last_sync</span>
                <strong>just now</strong>
            </div>
        </aside>
    </div>
</section>

<div class="marquee" aria-hidden="true">
    <div class="marquee-track">
        <span class="marquee-item"><strong>MICROSOFT GOLD PARTNER</strong></span>
        <span class="marquee-item"><strong>AWS SELECT PARTNER</strong></span>
        <span class="marquee-item"><strong>ESSENTIAL EIGHT</strong> aligned</span>
        <span class="marquee-item"><strong>ISO 27001</strong> in progress</span>
        <span class="marquee-item"><strong>120+</strong> active contracts</span>
        <span class="marquee-item"><strong>4,800+</strong> monitored endpoints</span>
        <span class="marquee-item"><strong>24/7</strong> NOC and SOC</span>
        <span class="marquee-item"><strong>PERTH</strong> headquartered</span>
        <span class="marquee-item"><strong>MICROSOFT GOLD PARTNER</strong></span>
        <span class="marquee-item"><strong>AWS SELECT PARTNER</strong></span>
        <span class="marquee-item"><strong>ESSENTIAL EIGHT</strong> aligned</span>
        <span class="marquee-item"><strong>ISO 27001</strong> in progress</span>
        <span class="marquee-item"><strong>120+</strong> active contracts</span>
        <span class="marquee-item"><strong>4,800+</strong> monitored endpoints</span>
        <span class="marquee-item"><strong>24/7</strong> NOC and SOC</span>
        <span class="marquee-item"><strong>PERTH</strong> headquartered</span>
    </div>
</div>

<section class="section-pad">
    <div class="wrap">
        <div class="section-header">
            <div>
                <p class="eyebrow">What we do</p>
                <h2>Engineering, not hand-waving.</h2>
            </div>
            <p class="lead">We don't pitch. We design, build, monitor, and respond. Every commitment we make is something we operate ourselves at 3am.</p>
        </div>

        <div class="cap-grid">
            <article class="cap">
                <div class="cap-num">01 / MANAGED_IT</div>
                <h3>Managed infrastructure</h3>
                <p>24/7 monitoring, proactive patching, helpdesk, and the boring-but-critical work that keeps mid-market businesses running. SLAs we actually meet.</p>
                <div class="cap-tags">
                    <span class="cap-tag">helpdesk</span>
                    <span class="cap-tag">monitoring</span>
                    <span class="cap-tag">patching</span>
                </div>
            </article>
            <article class="cap">
                <div class="cap-num">02 / CLOUD</div>
                <h3>Cloud and hybrid architecture</h3>
                <p>Cloud migrations, hybrid designs, infrastructure as code. We architect for the next five years, not the next demo.</p>
                <div class="cap-tags">
                    <span class="cap-tag">azure</span>
                    <span class="cap-tag">aws</span>
                    <span class="cap-tag">terraform</span>
                </div>
            </article>
            <article class="cap">
                <div class="cap-num">03 / SECURITY</div>
                <h3>Cybersecurity practice</h3>
                <p>Assessments, managed detection, incident response, and compliance work aligned to Essential Eight and ISO 27001. Growing 40% YoY.</p>
                <div class="cap-tags">
                    <span class="cap-tag">SIEM</span>
                    <span class="cap-tag">IR</span>
                    <span class="cap-tag">essential 8</span>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="metrics">
    <div class="wrap">
        <div class="metrics-header">
            <h2>By the numbers.</h2>
            <p class="label">// SNAPSHOT FY26</p>
        </div>
        <div class="metrics-grid">
            <div class="metric accent">
                <div class="metric-label">Active contracts</div>
                <div class="metric-value">120<span style="color:var(--np-cyan); font-size:0.6em;">+</span></div>
                <div class="metric-unit">Managed services</div>
            </div>
            <div class="metric">
                <div class="metric-label">Uptime SLA</div>
                <div class="metric-value">99.7<span style="font-size:0.5em;">%</span></div>
                <div class="metric-unit">Across client base</div>
            </div>
            <div class="metric">
                <div class="metric-label">First response</div>
                <div class="metric-value">12<span style="font-size:0.5em;">min</span></div>
                <div class="metric-unit">24/7 NOC average</div>
            </div>
            <div class="metric accent">
                <div class="metric-label">Security growth</div>
                <div class="metric-value">+40<span style="font-size:0.5em;">%</span></div>
                <div class="metric-unit">YoY revenue</div>
            </div>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="wrap">
        <div class="scenario">
            <p class="scenario-label">/// CURRENT_INITIATIVE</p>
            <h3>{{ scenario.name or "Security-First Pivot" }}</h3>
            <p>{{ (scenario.description or "")|trim }}</p>

            {% if scenario.key_tensions %}
            <ul class="scenario-tensions">
                {% for tension in scenario.key_tensions[:6] %}
                <li>{{ tension }}</li>
                {% endfor %}
            </ul>
            {% endif %}
        </div>
    </div>
</section>

<section class="cta-banner">
    <div class="wrap">
        <div class="cta-banner-inner">
            <div>
                <h2>We're hiring engineers who like solving real problems.</h2>
                <p>Security analysts, service desk, cloud architects, business analysts. We're a 35-person team — every hire matters and every role is real work, not a graduate cohort to manage.</p>
            </div>
            <a href="/careers.html" class="btn btn-cyan btn-arrow cta-banner-btn">View open roles</a>
        </div>
    </div>
</section>
{% endblock %}
