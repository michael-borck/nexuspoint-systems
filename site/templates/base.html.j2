<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}NexusPoint Systems — Managed IT and Cybersecurity{% endblock %}</title>
    <meta name="description" content="{% block description %}Perth-based managed IT services and cybersecurity for Western Australian mid-market businesses. Cloud, security, and 24/7 support.{% endblock %}">
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="stylesheet" href="/styles/main.css">
    {% block head_extra %}{% endblock %}
</head>
<body>
    <div class="status-bar">
        <div class="status-bar-inner">
            <span class="status-pip"><strong>NOC:</strong> 24/7 operational</span>
            <span class="status-pip cyan"><strong>SLA:</strong> 99.7% uptime</span>
            <span class="status-pip"><strong>RESPONSE:</strong> &lt;12 min avg</span>
            <span class="status-pip" style="margin-left:auto;"><strong>STATUS:</strong> All systems normal</span>
        </div>
    </div>

    <header class="header">
        <div class="header-inner">
            <a href="/" class="brand">
                <div class="brand-logo">NP</div>
                <div class="brand-name">
                    <strong>NexusPoint</strong>
                    <span>Systems / Perth WA</span>
                </div>
            </a>
            <nav class="nav">
                <a href="/" class="{% if page == 'index' %}active{% endif %}">Home</a>
                <a href="/about.html" class="{% if page == 'about' %}active{% endif %}">About</a>
                <a href="/services.html" class="{% if page == 'services' %}active{% endif %}">Services</a>
                <a href="/careers.html" class="{% if page == 'careers' %}active{% endif %}">Careers</a>
                <a href="/contact.html" class="{% if page == 'contact' %}active{% endif %}">Contact</a>
                <a href="/careers.html" class="nav-cta">Join us</a>
            </nav>
        </div>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="wrap">
            <div class="footer-grid">
                <div class="footer-brand">
                    <h3>NexusPoint Systems</h3>
                    <p>Managed IT services and cybersecurity for Western Australian mid-market businesses. 24/7 NOC, cloud expertise, and security-first by design.</p>
                </div>
                <div class="footer-col">
                    <h4>Company</h4>
                    <ul>
                        <li><a href="/about.html">About us</a></li>
                        <li><a href="/services.html">Services</a></li>
                        <li><a href="/careers.html">Careers</a></li>
                        <li><a href="/contact.html">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>For Staff</h4>
                    <ul>
                        <li><a href="/staff/">Staff portal</a></li>
                        <li><a href="/staff/directory.html">Directory</a></li>
                        <li><a href="/staff/documents.html">Documents</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Partners</h4>
                    <ul>
                        <li><a href="#">Microsoft Gold</a></li>
                        <li><a href="#">AWS Select</a></li>
                        <li><a href="#">Essential Eight</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; {{ year }} NEXUSPOINT SYSTEMS PTY LTD / ABN 00 000 000 000</p>
                <p class="footer-disclaimer">Fictional company — part of a Curtin University educational simulation. Not a real entity.</p>
            </div>
        </div>
    </footer>
</body>
</html>
