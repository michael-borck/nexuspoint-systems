{% extends "base.html.j2" %}

{% block title %}Staff login — NexusPoint Systems{% endblock %}

{% block content %}
<section class="section-pad">
    <div class="wrap-narrow">
        <p class="eyebrow">Staff portal</p>
        <h1 style="margin-bottom: var(--np-px-5);">Sign in.</h1>
        <p class="lead" style="margin-bottom: var(--np-px-6);">NexusPoint staff only. Enter your work email and we'll send a 6-digit access code.</p>

        <form id="login-form" style="max-width: 480px; display: grid; gap: var(--np-px-3); border: 1px solid var(--np-line); padding: var(--np-px-5); background: var(--np-bg);">
            <label class="label" for="email">WORK_EMAIL</label>
            <input type="email" id="email" name="email" required placeholder="firstname.lastname@nexuspointsystems.com.au" style="padding: var(--np-px-3); background: var(--np-bg-2); border: 1px solid var(--np-line-2); color: var(--np-text); font-family: var(--np-font-mono);">
            <button type="submit" class="btn btn-primary btn-arrow">Send code</button>
            <p class="mono" style="margin-top: var(--np-px-2); font-size: 0.7rem; color: var(--np-text-dim);">Authentication coming soon — placeholder for the WorkReady simulation.</p>
        </form>
    </div>
</section>
{% endblock %}
